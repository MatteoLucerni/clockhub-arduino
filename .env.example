# .env.example
# ---------------------------------------------------------------------------
# ClockHub Arduino - Credentials Template
#
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# The file .env is gitignored and will NEVER be committed.
# At build time, extra_scripts/load_env.py reads .env and auto-generates
# src/config.h before compilation.
# ---------------------------------------------------------------------------

# --- WiFi ---
WIFI_SSID=YourWiFiSSID
WIFI_PASS=YourWiFiPassword

# --- VoiceMonkey API (https://voicemonkey.io) ---
# Used to trigger an Alexa announcement as the wake-up light.
API_TOKEN=your_voicemonkey_api_token_here
MONKEY_ID=your_voicemonkey_device_id_here

# --- DuckDNS (https://www.duckdns.org) ---
# Dynamic DNS to keep the Arduino reachable by hostname.
DUCK_TOKEN=your-duckdns-token-here
DUCK_DOMAIN=your-duckdns-subdomain

# --- Web Interface PIN ---
# 6-digit numeric PIN for the web control panel.
ACCESS_PIN=000000

# --- Static IP Configuration ---
# Set a fixed LAN IP for the Arduino so the router always finds it.
ARDUINO_IP=192.168.1.100
GATEWAY_IP=192.168.1.1
SUBNET_MASK=255.255.255.0
DNS_IP=8.8.8.8

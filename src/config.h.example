// src/config.h.example
// ---------------------------------------------------------------------------
// Template for config.h - the file that holds all project credentials.
//
// HOW TO USE:
//   Do NOT edit this file directly.
//   Instead, copy .env.example to .env, fill in your real values,
//   and run a PlatformIO build. The script extra_scripts/load_env.py
//   will auto-generate src/config.h from your .env file.
//
//   cp .env.example .env
//   # edit .env with your actual credentials
//   pio run
//
// ---------------------------------------------------------------------------

#pragma once

// WiFi credentials
#define WIFI_SSID     "YourWiFiSSID"
#define WIFI_PASS     "YourWiFiPassword"

// VoiceMonkey API - https://voicemonkey.io
// Used to trigger an Alexa announcement as the wake-up light routine.
#define API_TOKEN     "your_voicemonkey_api_token_here"
#define MONKEY_ID     "your_voicemonkey_device_id_here"

// DuckDNS - https://www.duckdns.org
// Used to keep the Arduino's public IP address updated via dynamic DNS.
#define DUCK_TOKEN    "your-duckdns-token-here"
#define DUCK_DOMAIN   "your-duckdns-subdomain"

// Web interface PIN
// 6-digit numeric PIN used to access the web control panel.
#define ACCESS_PIN    "000000"

// Static IP configuration (comma-separated octets for IPAddress constructor)
// Example: 192.168.1.100 -> 192, 168, 1, 100
#define ARDUINO_IP_ARGS  192, 168, 1, 100
#define GATEWAY_IP_ARGS  192, 168, 1, 1
#define SUBNET_ARGS      255, 255, 255, 0
#define DNS_IP_ARGS      8, 8, 8, 8
